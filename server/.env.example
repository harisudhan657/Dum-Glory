# Resend API key (get from https://resend.com/api-keys)
RESEND_API_KEY=re_your_api_key_here

# Email that appears as the sender (must be a verified Resend domain)
EMAIL_FROM=Dum & Glory <reservations@yourdomain.com>

# Where reservation notifications are sent (your email)
RECIPIENT_EMAIL=your@email.com

# Frontend URL (for CORS — set to your Vercel URL in production)
FRONTEND_URL=http://localhost:5173

# Server port (optional, defaults to 4000)
PORT=4000
